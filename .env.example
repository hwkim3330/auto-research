# Choose one provider: ollama | anthropic | openai
LLM_PROVIDER=ollama

# Ollama (local; no cloud API key required)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_NUM_CTX=32768
OLLAMA_MODEL=gemma4:e4b-mlx
OLLAMA_MIDDLE_MODEL=gemma4:e4b-mlx
OLLAMA_STRONG_MODEL=gemma4:e4b-mlx

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_STRONG_MODEL=claude-opus-4-8

# OpenAI (used if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.6-luna
OPENAI_MIDDLE_MODEL=gpt-5.6-terra
OPENAI_STRONG_MODEL=gpt-5.6-sol
